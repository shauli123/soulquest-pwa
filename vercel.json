{
  "version": 2,
  "framework": "vite",
  "functions": {
    "server/index.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/trpc/:path*",
      "destination": "/server/index.ts"
    },
    {
      "source": "/assets/:path*",
      "destination": "/client/assets/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/client/index.html"
    }
  ]
}
