{
  "version": 2,
  "functions": {
    "server/_core/index.ts": {
      "runtime": "vercel-nodejs@20.x",
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/trpc/(.*)",
      "dest": "server/_core/index.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
